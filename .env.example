# ============================================================
# HR Agent — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
# Получить у @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenRouter (LLM) ─────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Модель LLM ───────────────────────────────────────────────
DEFAULT_MODEL=qwen/qwen3.6-35b-a3b
LLM_TIMEOUT=180
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.5

# ── Логирование ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hr_agent
POSTGRES_USER=hr_agent
POSTGRES_PASSWORD=your_postgres_password_here

# ── HR пользователь ──────────────────────────────────────────
# Telegram ID аккаунта, который будет иметь права HR
# Узнать свой ID можно у бота @userinfobot
HR_TELEGRAM_ID=0
HR_IDS=

# ── Почта для приёма резюме (IMAP) ───────────────────────────
EMAIL_HOST=imap.mail.ru
EMAIL_PORT=993
EMAIL_USER=your_email@mail.ru
EMAIL_PASSWORD=your_email_password_here

# ── SMTP для отправки писем ──────────────────────────────────
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your_email@mail.ru
SMTP_PASSWORD=your_smtp_password_here

# ── Собеседования ────────────────────────────────────────────
INTERVIEW_ADDRESS=г. Город, ул. Улица, д. 1, офис 101
INTERVIEW_REMINDER_TEXT=Не забудьте паспорт и резюме!
INTERVIEW_WORKING_HOURS_START=09:00
INTERVIEW_WORKING_HOURS_END=18:00
INTERVIEW_SLOT_INTERVAL_MINUTES=60
